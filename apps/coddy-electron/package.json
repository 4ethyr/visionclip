{
  "name": "coddy-electron",
  "version": "0.1.0",
  "description": "Coddy REPL — Electron + TypeScript + TailwindCSS Frontend",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "electron:dev": "VITE_DEV_SERVER_URL=http://localhost:5173 electron dist/main/main.js",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
